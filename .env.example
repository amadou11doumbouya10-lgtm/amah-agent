# Copie ce fichier en .env et remplis tes clés

# --- Groq (obligatoire) ---
# Clé gratuite sur : https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Gmail (optionnel) ---
# Nécessaire uniquement pour les outils email (read_emails, send_email, search_emails)
# Setup :
#   1. Active la validation en 2 étapes sur ton compte Google
#   2. Va dans : Compte Google → Sécurité → Mots de passe des applications
#   3. Crée un mot de passe pour "Autre" → copie le code 16 caractères ci-dessous
GMAIL_ADDRESS=contact.amah.officiel@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- ElevenLabs (optionnel) ---
# Nécessaire uniquement pour les scripts de génération audio dans voix/
# Clé sur : https://elevenlabs.io → Profil → API Keys
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx